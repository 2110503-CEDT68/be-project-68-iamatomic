@startuml Manage Booking (DELETE)
actor Client
participant Router
participant AuthMiddleware
participant BookingController
participant BookingModel
database MongoDB

Client -> Router : DELETE /bookings/:id
Router -> AuthMiddleware : protect()
AuthMiddleware --> Router : req.user

Router -> BookingController : deleteBooking()

BookingController -> BookingModel : findById(id)
BookingModel -> MongoDB
MongoDB --> BookingModel : booking/null
BookingModel --> BookingController

alt Not found
    BookingController -> Client : 404
else Found
    alt Not owner AND not admin
        BookingController -> Client : 401 Unauthorized
    else Authorized
        BookingController -> BookingModel : deleteOne()
        BookingModel -> MongoDB
        MongoDB --> BookingModel
        BookingController -> Client : 200 OK
    end
end

@enduml